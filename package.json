{
    "name": "bobril",
    "version": "21.7.0",
    "description": "Component Oriented MVC Framework with virtual DOM and CSS",
    "license": "MIT",
    "author": "Boris Letocha",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Bobris/Bobril.git",
        "directory": "package"
    },
    "main": "index.js",
    "types": "index.d.ts",
    "scripts": {
        "prepublishOnly": "oxfmt --write index.ts src spec package.json && bb test",
        "test": "bb test"
    },
    "devDependencies": {
        "oxfmt": "*",
        "typescript": "*"
    },
    "typescript": {
        "main": "index.ts"
    },
    "bobril": {
        "compilerOptions": {
            "target": "ES2018",
            "lib": [
                "ES2018",
                "dom"
            ],
            "noImplicitAny": true,
            "noImplicitThis": true,
            "noUnusedLocals": true,
            "noUnusedParameters": true,
            "noImplicitReturns": true,
            "noFallthroughCasesInSwitch": true,
            "noUncheckedIndexedAccess": true,
            "strictNullChecks": true,
            "strict": true,
            "noPropertyAccessFromIndexSignature": true,
            "reactNamespace": "b"
        }
    }
}
